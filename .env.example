# Copy to .env.local to override per environment.

# beta -> TestFlight button + Android notify | waitlist -> email capture
# | live -> App Store buttons
VITE_LAUNCH_MODE=beta

# iOS beta (TestFlight public) link for beta mode. Blank = button disabled.
VITE_BETA_URL=

# Endpoint that receives { email, surface, platform } as JSON POST.
# Blank = no-op success (offline demos).
VITE_WAITLIST_ENDPOINT=https://staging-reembr-backend.vercel.app/api/waitlist
