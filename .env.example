# Copy to .env.local to override per environment.

# beta -> TestFlight button + Android notify | waitlist -> email capture
# | live -> App Store buttons
VITE_LAUNCH_MODE=beta

# iOS beta (TestFlight public) link for beta mode. Blank = button disabled.
VITE_BETA_URL=

# Endpoint that receives { email, surface, platform } as JSON POST — the
# backend's POST /api/waitlist. Dev: http://localhost:3000/api/waitlist
# Prod: the deployed backend URL. Blank = no-op success (offline demos).
VITE_WAITLIST_ENDPOINT=http://localhost:3000/api/waitlist
